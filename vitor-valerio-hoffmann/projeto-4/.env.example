# Copie para .env e preencha
ANTHROPIC_API_KEY=sk-ant-...

# Modelo Claude usado na extração semântica
UDA_LLM_MODEL=claude-sonnet-4-6

# Limite (em tokens estimados) para decidir full-scan vs chunking
UDA_FULLSCAN_TOKEN_LIMIT=6000

# Caminho do banco SQLite (catálogo + dados + linhagem)
UDA_DB_PATH=data/catalog.db

# Intervalo de polling do scheduler, em horas
UDA_POLL_INTERVAL_HOURS=24
